<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Imunisasi - <%= balita.nama %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-kader">
    <div class="nav-brand"><span class="logo-sm">👩‍⚕️</span><span>Panel Kader</span></div>
    <a href="/kader/balita/<%= balita.id %>" class="btn btn-outline btn-sm">← Kembali</a>
  </nav>
  <main class="container container-narrow">
    <h1>Catat Imunisasi</h1>
    <p class="subtitle">Balita: <strong><%= balita.nama %></strong></p>
    <form action="/kader/imunisasi/<%= balita.id %>" method="POST" class="card form-card">
      <div class="form-group">
        <label>Nama Vaksin *</label>
        <input type="text" name="nama_vaksin" required placeholder="cth: DPT-HB-Hib 2">
      </div>
      <div class="form-group">
        <label>Tanggal *</label>
        <input type="date" name="tanggal" required>
      </div>
      <div class="form-group">
        <label>Catatan</label>
        <input type="text" name="catatan" placeholder="Dosis, reaksi, dll.">
      </div>
      <button type="submit" class="btn btn-primary btn-block">Simpan</button>
    </form>
  </main>
</body>
</html>

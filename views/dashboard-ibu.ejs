<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - <%= balita.nama %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <span class="logo-sm">🏥</span>
      <span>Posyandu Candiareng</span>
    </div>
    <div class="nav-user">
      <span>Halo, <%= user.nama %></span>
      <a href="/logout" class="btn btn-outline btn-sm">Keluar</a>
    </div>
  </nav>

  <main class="container">
    <div class="page-header">
      <div>
        <h1>Data Pertumbuhan Balita</h1>
        <p class="subtitle">Monitoring BB, TB, dan status stunting anak Anda</p>
      </div>
      <% if (semuaAnak.length > 1) { %>
        <form action="/dashboard/pilih-anak" method="POST" class="anak-selector">
          <label>Pilih Anak:</label>
          <select name="balita_id" onchange="this.form.submit()">
            <% semuaAnak.forEach(a => { %>
              <option value="<%= a.id %>" <%= a.id === activeBalitaId ? 'selected' : '' %>><%= a.nama %></option>
            <% }) %>
          </select>
        </form>
      <% } %>
    </div>

    <!-- Profil Anak -->
    <section class="card profile-card">
      <div class="profile-avatar"><%= balita.jenis_kelamin === 'L' ? '👦' : '👧' %></div>
      <div class="profile-info">
        <h2><%= balita.nama %></h2>
        <div class="profile-meta">
          <span><strong>Tgl Lahir:</strong> <%= formatTanggal(balita.tanggal_lahir) %></span>
          <span><strong>Umur:</strong> <%= umurText %></span>
          <span><strong>Jenis Kelamin:</strong> <%= balita.jenis_kelamin === 'L' ? 'Laki-laki' : 'Perempuan' %></span>
          <span><strong>Ibu:</strong> <%= balita.nama_ibu %></span>
        </div>
      </div>
    </section>

  <% if (terakhir && stunting) { %>
    <!-- Status Terkini -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Berat Badan Terakhir</div>
        <div class="stat-value"><%= terakhir.berat_badan %> <small>kg</small></div>
        <div class="stat-badge badge-<%= bbStatus.status === 'Normal' ? 'success' : 'warning' %>"><%= bbStatus.status %></div>
        <div class="stat-date"><%= formatTanggal(terakhir.tanggal) %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Tinggi Badan Terakhir</div>
        <div class="stat-value"><%= terakhir.tinggi_badan %> <small>cm</small></div>
        <div class="stat-badge badge-<%= stunting.warna %>"><%= stunting.status %></div>
        <div class="stat-date"><%= formatTanggal(terakhir.tanggal) %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Lingkar Kepala</div>
        <div class="stat-value"><%= terakhir.lingkar_kepala || '-' %> <small>cm</small></div>
        <div class="stat-date"><%= formatTanggal(terakhir.tanggal) %></div>
      </div>
      <div class="stat-card stat-highlight">
        <div class="stat-label">Status Stunting (TB/U)</div>
        <div class="stat-value stat-<%= stunting.warna %>"><%= stunting.status %></div>
        <p class="stat-desc"><%= stunting.keterangan %></p>
      </div>
    </div>

    <!-- Grafik Pertumbuhan -->
    <section class="card">
      <h3 class="card-title">Grafik Pertumbuhan</h3>
      <div class="chart-grid">
        <div class="chart-box">
          <canvas id="chartBB"></canvas>
        </div>
        <div class="chart-box">
          <canvas id="chartTB"></canvas>
        </div>
      </div>
    </section>
  <% } else { %>
    <div class="alert alert-info">Belum ada data kunjungan Posyandu. Silakan hubungi kader Posyandu.</div>
  <% } %>

    <!-- Riwayat Kunjungan -->
    <section class="card">
      <h3 class="card-title">Riwayat Kunjungan Posyandu</h3>
      <% if (kunjungan.length > 0) { %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Tanggal</th>
                <th>BB (kg)</th>
                <th>TB (cm)</th>
                <th>LK (cm)</th>
                <th>Status BB</th>
                <th>Status TB/Stunting</th>
                <th>Catatan</th>
              </tr>
            </thead>
            <tbody>
              <% kunjungan.slice().reverse().forEach(k => { %>
                <tr>
                  <td><%= formatTanggal(k.tanggal) %></td>
                  <td><%= k.berat_badan %></td>
                  <td><%= k.tinggi_badan %></td>
                  <td><%= k.lingkar_kepala || '-' %></td>
                  <td><span class="badge badge-<%= k.bbStatus.status === 'Normal' ? 'success' : 'warning' %>"><%= k.bbStatus.status %></span></td>
                  <td><span class="badge badge-<%= k.stunting.warna %>"><%= k.stunting.status %></span></td>
                  <td><%= k.catatan || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="empty">Belum ada riwayat kunjungan.</p>
      <% } %>
    </section>

    <!-- Imunisasi & Vitamin -->
    <div class="two-col">
      <section class="card">
        <h3 class="card-title">Riwayat Imunisasi</h3>
        <% if (imunisasi.length > 0) { %>
          <ul class="timeline">
            <% imunisasi.forEach(i => { %>
              <li class="timeline-item">
                <div class="timeline-date"><%= formatTanggal(i.tanggal) %></div>
                <div class="timeline-content">
                  <strong><%= i.nama_vaksin %></strong>
                  <% if (i.catatan) { %><p><%= i.catatan %></p><% } %>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="empty">Belum ada data imunisasi.</p>
        <% } %>
      </section>

      <section class="card">
        <h3 class="card-title">Riwayat Pemberian Vitamin</h3>
        <% if (vitamin.length > 0) { %>
          <ul class="timeline">
            <% vitamin.forEach(v => { %>
              <li class="timeline-item">
                <div class="timeline-date"><%= formatTanggal(v.tanggal) %></div>
                <div class="timeline-content">
                  <strong><%= v.jenis %></strong>
                  <% if (v.catatan) { %><p><%= v.catatan %></p><% } %>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="empty">Belum ada data vitamin.</p>
        <% } %>
      </section>
    </div>
  </main>

  <% if (kunjungan.length > 0) { %>
  <script>
    const labels = <%- JSON.stringify(kunjungan.map(k => k.tanggal)) %>;
    const bbData = <%- JSON.stringify(kunjungan.map(k => k.berat_badan)) %>;
    const tbData = <%- JSON.stringify(kunjungan.map(k => k.tinggi_badan)) %>;

    const chartOpts = {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: false } }
    };

    new Chart(document.getElementById('chartBB'), {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Berat Badan (kg)',
          data: bbData,
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37,99,235,0.1)',
          fill: true,
          tension: 0.3
        }]
      },
      options: { ...chartOpts, plugins: { legend: { display: true, position: 'top' } } }
    });

    new Chart(document.getElementById('chartTB'), {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Tinggi Badan (cm)',
          data: tbData,
          borderColor: '#16a34a',
          backgroundColor: 'rgba(22,163,74,0.1)',
          fill: true,
          tension: 0.3
        }]
      },
      options: { ...chartOpts, plugins: { legend: { display: true, position: 'top' } } }
    });
  </script>
  <% } %>
</body>
</html>

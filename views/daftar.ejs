<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar Akun - Posyandu Desa Candiareng</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="auth-page">
  <div class="auth-container auth-container-wide">
    <div class="auth-header">
      <div class="logo">📝</div>
      <h1>Daftar Akun Baru</h1>
      <p>Posyandu Desa Candiareng</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/daftar" method="POST" class="form">
      <h3 class="form-section-title">Data Ibu / Orang Tua</h3>
      <div class="form-group">
        <label for="nik">NIK Ibu *</label>
        <input type="text" id="nik" name="nik" maxlength="16" minlength="16" placeholder="16 digit NIK" required value="<%= typeof form !== 'undefined' ? form.nik || '' : '' %>">
      </div>
      <div class="form-group">
        <label for="nama_ibu">Nama Lengkap Ibu *</label>
        <input type="text" id="nama_ibu" name="nama_ibu" placeholder="Nama lengkap" required value="<%= typeof form !== 'undefined' ? form.nama_ibu || '' : '' %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="password">Password *</label>
          <input type="password" id="password" name="password" placeholder="Min. 6 karakter" minlength="6" required>
        </div>
        <div class="form-group">
          <label for="password_confirm">Konfirmasi Password *</label>
          <input type="password" id="password_confirm" name="password_confirm" placeholder="Ulangi password" minlength="6" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="no_hp">No. HP</label>
          <input type="text" id="no_hp" name="no_hp" placeholder="08xxxxxxxxxx" value="<%= typeof form !== 'undefined' ? form.no_hp || '' : '' %>">
        </div>
        <div class="form-group">
          <label for="alamat">Alamat</label>
          <input type="text" id="alamat" name="alamat" placeholder="RT/RW, Desa Candiareng" value="<%= typeof form !== 'undefined' ? form.alamat || '' : '' %>">
        </div>
      </div>

      <h3 class="form-section-title">Data Balita</h3>
      <div class="form-group">
        <label for="nama_anak">Nama Anak *</label>
        <input type="text" id="nama_anak" name="nama_anak" placeholder="Nama lengkap anak" required value="<%= typeof form !== 'undefined' ? form.nama_anak || '' : '' %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="tanggal_lahir">Tanggal Lahir Anak *</label>
          <input type="date" id="tanggal_lahir" name="tanggal_lahir" required value="<%= typeof form !== 'undefined' ? form.tanggal_lahir || '' : '' %>">
        </div>
        <div class="form-group">
          <label for="jenis_kelamin">Jenis Kelamin *</label>
          <select id="jenis_kelamin" name="jenis_kelamin" required>
            <option value="">-- Pilih --</option>
            <option value="L" <%= typeof form !== 'undefined' && form.jenis_kelamin === 'L' ? 'selected' : '' %>>Laki-laki</option>
            <option value="P" <%= typeof form !== 'undefined' && form.jenis_kelamin === 'P' ? 'selected' : '' %>>Perempuan</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="nik_balita">NIK Balita (opsional)</label>
        <input type="text" id="nik_balita" name="nik_balita" maxlength="16" placeholder="16 digit NIK anak" value="<%= typeof form !== 'undefined' ? form.nik_balita || '' : '' %>">
      </div>

      <button type="submit" class="btn btn-primary btn-block">Daftar Sekarang</button>
    </form>

    <div class="auth-footer">
      <p>Sudah punya akun? <a href="/login">Masuk di sini</a></p>
      <p>Untuk kader: <a href="/kader/login">Login Kader</a></p>
    </div>
  </div>
</body>
</html>

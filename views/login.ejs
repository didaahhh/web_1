<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Posyandu Desa Candiareng</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="auth-page">
  <div class="auth-container">
    <div class="auth-header">
      <div class="logo">🏥</div>
      <h1>Posyandu Desa Candiareng</h1>
      <p>Web Pendataan Riwayat Balita</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="tabs">
      <button class="tab-btn <%= tab === 'nik' ? 'active' : '' %>" data-tab="nik">NIK & Password</button>
      <button class="tab-btn <%= tab === 'anak' ? 'active' : '' %>" data-tab="anak">Nama & Tgl Lahir Anak</button>
    </div>

    <div class="tab-content <%= tab === 'nik' ? 'active' : '' %>" id="tab-nik">
      <form action="/login/nik" method="POST" class="form">
        <div class="form-group">
          <label for="nik">NIK Ibu</label>
          <input type="text" id="nik" name="nik" placeholder="Masukkan 16 digit NIK" maxlength="16" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Masukkan password" required>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Masuk</button>
      </form>
    </div>

    <div class="tab-content <%= tab === 'anak' ? 'active' : '' %>" id="tab-anak">
      <form action="/login/anak" method="POST" class="form">
        <div class="form-group">
          <label for="nama_anak">Nama Anak</label>
          <input type="text" id="nama_anak" name="nama_anak" placeholder="Nama lengkap anak" required>
        </div>
        <div class="form-group">
          <label for="tanggal_lahir">Tanggal Lahir Anak</label>
          <input type="date" id="tanggal_lahir" name="tanggal_lahir" required>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Masuk</button>
      </form>
    </div>

    <div class="auth-footer">
      <p>Belum punya akun? <a href="/daftar">Daftar di sini</a></p>
      <p>Untuk kader Posyandu: <a href="/kader/login">Login Kader</a></p>
    </div>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
